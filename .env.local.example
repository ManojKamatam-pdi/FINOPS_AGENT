# Okta (user-facing PKCE app)
OKTA_ISSUER=https://your-domain.okta.com
OKTA_CLIENT_ID=your-okta-client-id

# MCP Registry — central config for all MCP servers (JSON array)
# auth modes: "okta_forward" | "none" | "env:MY_VAR_NAME"
# Example with multiple MCPs:
#   MCP_REGISTRY=[{"name":"datadog","url":"https://...","transport":"http","auth":"okta_forward"},{"name":"github","url":"https://...","transport":"http","auth":"env:GITHUB_TOKEN"}]
MCP_REGISTRY=[{"name":"datadog","url":"https://dm9vya05q5.execute-api.us-east-1.amazonaws.com/mcp","transport":"http","auth":"okta_forward"}]

# Datadog MCP — legacy fallback (used if MCP_REGISTRY is not set)
DATADOG_MCP_URL=https://dm9vya05q5.execute-api.us-east-1.amazonaws.com/mcp

# DynamoDB — localhost port (backend runs natively, DynamoDB runs in Docker on port 8003)
DYNAMODB_ENDPOINT=http://127.0.0.1:8003
