# Anthropic / PDI Gateway
ANTHROPIC_BASE_URL=https://pdi-gateway.pditechnologies.com/v1
ANTHROPIC_AUTH_TOKEN=your-token-here

# Okta (user-facing PKCE app)
OKTA_ISSUER=https://your-domain.okta.com
OKTA_CLIENT_ID=your-okta-client-id

# Okta M2M (Client Credentials for scheduler)
OKTA_M2M_CLIENT_ID=your-m2m-client-id
OKTA_M2M_CLIENT_SECRET=your-m2m-client-secret

# Datadog MCP
DATADOG_MCP_URL=https://dm9vya05q5.execute-api.us-east-1.amazonaws.com/mcp

# AWS (for Pricing API)
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your-access-key
AWS_SECRET_ACCESS_KEY=your-secret-key

# Local DynamoDB (presence of this var enables APScheduler + local DynamoDB mode)
DYNAMODB_ENDPOINT=http://localhost:8000

# Scheduler cron (2am nightly)
SCHEDULER_CRON=0 2 * * *
