{
  "name": "finops-agent",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev": "docker-compose up --build",
    "dev:down": "docker-compose down",
    "deploy": "sst deploy",
    "deploy:prod": "sst deploy --stage prod",
    "test:setup": "npx playwright test --project=setup",
    "test:e2e": "npx playwright test --project=e2e",
    "test:report": "npx playwright show-report playwright/report"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "typescript": "^5.9.3"
  }
}
